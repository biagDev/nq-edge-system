//@version=5
indicator("1030 Hit Stats", overlay=true, max_labels_count=500)

h = hour(time, "America/New_York")
m = minute(time, "America/New_York")
dow = dayofweek(time, "America/New_York")

// Subject: 10:30-10:45 ET
isOpenBar = h == 10 and m == 30
isPost1   = h == 10 and m == 45  // 10:45-11:00 -> by 11:00
isPost2   = h == 11 and m == 0   // 11:00-11:15 -> by 11:15
isPost3   = h == 11 and m == 15  // 11:15-11:30 -> by 11:30 (final tally)

var float openHigh = na
var float openLow  = na
var int   openDow  = na

var bool hiHit1 = false
var bool loHit1 = false
var bool hiHit2 = false
var bool loHit2 = false
var bool hiHit3 = false
var bool loHit3 = false

var int totalDays = 0

var int e1 = 0
var int b1 = 0
var int ho1 = 0
var int lo1 = 0
var int n1 = 0
var int ha1 = 0
var int la1 = 0

var int e2 = 0
var int b2 = 0
var int ho2 = 0
var int lo2 = 0
var int n2 = 0
var int ha2 = 0
var int la2 = 0

var int e3 = 0
var int b3 = 0
var int ho3 = 0
var int lo3 = 0
var int n3 = 0
var int ha3 = 0
var int la3 = 0

var int[] dD = array.new_int(8, 0)

var int[] dE1 = array.new_int(8, 0)
var int[] dB1 = array.new_int(8, 0)
var int[] dH1 = array.new_int(8, 0)
var int[] dL1 = array.new_int(8, 0)
var int[] dN1 = array.new_int(8, 0)

var int[] dE2 = array.new_int(8, 0)
var int[] dB2 = array.new_int(8, 0)
var int[] dH2 = array.new_int(8, 0)
var int[] dL2 = array.new_int(8, 0)
var int[] dN2 = array.new_int(8, 0)

var int[] dE3 = array.new_int(8, 0)
var int[] dB3 = array.new_int(8, 0)
var int[] dH3 = array.new_int(8, 0)
var int[] dL3 = array.new_int(8, 0)
var int[] dN3 = array.new_int(8, 0)

if isOpenBar
    openHigh := high
    openLow  := low
    openDow  := dow
    hiHit1 := false
    loHit1 := false
    hiHit2 := false
    loHit2 := false
    hiHit3 := false
    loHit3 := false

if isPost1 and not na(openHigh)
    if high >= openHigh
        hiHit1 := true
        hiHit2 := true
        hiHit3 := true
    if low <= openLow
        loHit1 := true
        loHit2 := true
        loHit3 := true

if isPost2 and not na(openHigh)
    if high >= openHigh
        hiHit2 := true
        hiHit3 := true
    if low <= openLow
        loHit2 := true
        loHit3 := true

if isPost3 and not na(openHigh)
    if high >= openHigh
        hiHit3 := true
    if low <= openLow
        loHit3 := true

    totalDays += 1

    if hiHit1
        ha1 += 1
    if loHit1
        la1 += 1
    if hiHit1 and loHit1
        b1 += 1
        e1 += 1
    else if hiHit1
        ho1 += 1
        e1 += 1
    else if loHit1
        lo1 += 1
        e1 += 1
    else
        n1 += 1

    if hiHit2
        ha2 += 1
    if loHit2
        la2 += 1
    if hiHit2 and loHit2
        b2 += 1
        e2 += 1
    else if hiHit2
        ho2 += 1
        e2 += 1
    else if loHit2
        lo2 += 1
        e2 += 1
    else
        n2 += 1

    if hiHit3
        ha3 += 1
    if loHit3
        la3 += 1
    if hiHit3 and loHit3
        b3 += 1
        e3 += 1
    else if hiHit3
        ho3 += 1
        e3 += 1
    else if loHit3
        lo3 += 1
        e3 += 1
    else
        n3 += 1

    d = openDow
    if d >= 2 and d <= 6
        array.set(dD, d, array.get(dD, d) + 1)
        if hiHit1 and loHit1
            array.set(dB1, d, array.get(dB1, d) + 1)
            array.set(dE1, d, array.get(dE1, d) + 1)
        else if hiHit1
            array.set(dH1, d, array.get(dH1, d) + 1)
            array.set(dE1, d, array.get(dE1, d) + 1)
        else if loHit1
            array.set(dL1, d, array.get(dL1, d) + 1)
            array.set(dE1, d, array.get(dE1, d) + 1)
        else
            array.set(dN1, d, array.get(dN1, d) + 1)
        if hiHit2 and loHit2
            array.set(dB2, d, array.get(dB2, d) + 1)
            array.set(dE2, d, array.get(dE2, d) + 1)
        else if hiHit2
            array.set(dH2, d, array.get(dH2, d) + 1)
            array.set(dE2, d, array.get(dE2, d) + 1)
        else if loHit2
            array.set(dL2, d, array.get(dL2, d) + 1)
            array.set(dE2, d, array.get(dE2, d) + 1)
        else
            array.set(dN2, d, array.get(dN2, d) + 1)
        if hiHit3 and loHit3
            array.set(dB3, d, array.get(dB3, d) + 1)
            array.set(dE3, d, array.get(dE3, d) + 1)
        else if hiHit3
            array.set(dH3, d, array.get(dH3, d) + 1)
            array.set(dE3, d, array.get(dE3, d) + 1)
        else if loHit3
            array.set(dL3, d, array.get(dL3, d) + 1)
            array.set(dE3, d, array.get(dE3, d) + 1)
        else
            array.set(dN3, d, array.get(dN3, d) + 1)

f_pct(num, den) =>
    den > 0 ? num * 100.0 / den : 0.0

var table tAgg = table.new(position.top_right, 7, 10, border_width=1)
var table tDow = table.new(position.middle_right, 17, 7, border_width=1)

if barstate.islast
    table.cell(tAgg, 0, 0, "Aggregate",  bgcolor=color.navy, text_color=color.white)
    table.cell(tAgg, 1, 0, "11:00 #",    bgcolor=color.navy, text_color=color.white)
    table.cell(tAgg, 2, 0, "11:00 %",    bgcolor=color.navy, text_color=color.white)
    table.cell(tAgg, 3, 0, "11:15 #",    bgcolor=color.navy, text_color=color.white)
    table.cell(tAgg, 4, 0, "11:15 %",    bgcolor=color.navy, text_color=color.white)
    table.cell(tAgg, 5, 0, "11:30 #",    bgcolor=color.navy, text_color=color.white)
    table.cell(tAgg, 6, 0, "11:30 %",    bgcolor=color.navy, text_color=color.white)

    table.cell(tAgg, 0, 1, "Total days")
    table.cell(tAgg, 1, 1, str.tostring(totalDays))
    table.cell(tAgg, 2, 1, "100")
    table.cell(tAgg, 3, 1, str.tostring(totalDays))
    table.cell(tAgg, 4, 1, "100")
    table.cell(tAgg, 5, 1, str.tostring(totalDays))
    table.cell(tAgg, 6, 1, "100")

    table.cell(tAgg, 0, 2, "Either side")
    table.cell(tAgg, 1, 2, str.tostring(e1))
    table.cell(tAgg, 2, 2, str.tostring(f_pct(e1, totalDays), "#.##"))
    table.cell(tAgg, 3, 2, str.tostring(e2))
    table.cell(tAgg, 4, 2, str.tostring(f_pct(e2, totalDays), "#.##"))
    table.cell(tAgg, 5, 2, str.tostring(e3))
    table.cell(tAgg, 6, 2, str.tostring(f_pct(e3, totalDays), "#.##"))

    table.cell(tAgg, 0, 3, "Both sides")
    table.cell(tAgg, 1, 3, str.tostring(b1))
    table.cell(tAgg, 2, 3, str.tostring(f_pct(b1, totalDays), "#.##"))
    table.cell(tAgg, 3, 3, str.tostring(b2))
    table.cell(tAgg, 4, 3, str.tostring(f_pct(b2, totalDays), "#.##"))
    table.cell(tAgg, 5, 3, str.tostring(b3))
    table.cell(tAgg, 6, 3, str.tostring(f_pct(b3, totalDays), "#.##"))

    table.cell(tAgg, 0, 4, "High only")
    table.cell(tAgg, 1, 4, str.tostring(ho1))
    table.cell(tAgg, 2, 4, str.tostring(f_pct(ho1, totalDays), "#.##"))
    table.cell(tAgg, 3, 4, str.tostring(ho2))
    table.cell(tAgg, 4, 4, str.tostring(f_pct(ho2, totalDays), "#.##"))
    table.cell(tAgg, 5, 4, str.tostring(ho3))
    table.cell(tAgg, 6, 4, str.tostring(f_pct(ho3, totalDays), "#.##"))

    table.cell(tAgg, 0, 5, "Low only")
    table.cell(tAgg, 1, 5, str.tostring(lo1))
    table.cell(tAgg, 2, 5, str.tostring(f_pct(lo1, totalDays), "#.##"))
    table.cell(tAgg, 3, 5, str.tostring(lo2))
    table.cell(tAgg, 4, 5, str.tostring(f_pct(lo2, totalDays), "#.##"))
    table.cell(tAgg, 5, 5, str.tostring(lo3))
    table.cell(tAgg, 6, 5, str.tostring(f_pct(lo3, totalDays), "#.##"))

    table.cell(tAgg, 0, 6, "Neither")
    table.cell(tAgg, 1, 6, str.tostring(n1))
    table.cell(tAgg, 2, 6, str.tostring(f_pct(n1, totalDays), "#.##"))
    table.cell(tAgg, 3, 6, str.tostring(n2))
    table.cell(tAgg, 4, 6, str.tostring(f_pct(n2, totalDays), "#.##"))
    table.cell(tAgg, 5, 6, str.tostring(n3))
    table.cell(tAgg, 6, 6, str.tostring(f_pct(n3, totalDays), "#.##"))

    table.cell(tAgg, 0, 7, "High touched (any)")
    table.cell(tAgg, 1, 7, str.tostring(ha1))
    table.cell(tAgg, 2, 7, str.tostring(f_pct(ha1, totalDays), "#.##"))
    table.cell(tAgg, 3, 7, str.tostring(ha2))
    table.cell(tAgg, 4, 7, str.tostring(f_pct(ha2, totalDays), "#.##"))
    table.cell(tAgg, 5, 7, str.tostring(ha3))
    table.cell(tAgg, 6, 7, str.tostring(f_pct(ha3, totalDays), "#.##"))

    table.cell(tAgg, 0, 8, "Low touched (any)")
    table.cell(tAgg, 1, 8, str.tostring(la1))
    table.cell(tAgg, 2, 8, str.tostring(f_pct(la1, totalDays), "#.##"))
    table.cell(tAgg, 3, 8, str.tostring(la2))
    table.cell(tAgg, 4, 8, str.tostring(f_pct(la2, totalDays), "#.##"))
    table.cell(tAgg, 5, 8, str.tostring(la3))
    table.cell(tAgg, 6, 8, str.tostring(f_pct(la3, totalDays), "#.##"))

    headers = array.from("DOW", "N", "EitW1%", "BthW1%", "HiW1", "LoW1", "NeiW1", "EitW2%", "BthW2%", "HiW2", "LoW2", "NeiW2", "EitW3%", "BthW3%", "HiW3", "LoW3", "NeiW3")
    for i = 0 to 16
        table.cell(tDow, i, 0, array.get(headers, i), bgcolor=color.navy, text_color=color.white)
    dowNames = array.from("", "", "Mon", "Tue", "Wed", "Thu", "Fri")
    for d = 2 to 6
        n = array.get(dD, d)
        row = d - 1
        table.cell(tDow, 0,  row, array.get(dowNames, d))
        table.cell(tDow, 1,  row, str.tostring(n))
        table.cell(tDow, 2,  row, str.tostring(f_pct(array.get(dE1, d), n), "#.##"))
        table.cell(tDow, 3,  row, str.tostring(f_pct(array.get(dB1, d), n), "#.##"))
        table.cell(tDow, 4,  row, str.tostring(array.get(dH1, d)))
        table.cell(tDow, 5,  row, str.tostring(array.get(dL1, d)))
        table.cell(tDow, 6,  row, str.tostring(array.get(dN1, d)))
        table.cell(tDow, 7,  row, str.tostring(f_pct(array.get(dE2, d), n), "#.##"))
        table.cell(tDow, 8,  row, str.tostring(f_pct(array.get(dB2, d), n), "#.##"))
        table.cell(tDow, 9,  row, str.tostring(array.get(dH2, d)))
        table.cell(tDow, 10, row, str.tostring(array.get(dL2, d)))
        table.cell(tDow, 11, row, str.tostring(array.get(dN2, d)))
        table.cell(tDow, 12, row, str.tostring(f_pct(array.get(dE3, d), n), "#.##"))
        table.cell(tDow, 13, row, str.tostring(f_pct(array.get(dB3, d), n), "#.##"))
        table.cell(tDow, 14, row, str.tostring(array.get(dH3, d)))
        table.cell(tDow, 15, row, str.tostring(array.get(dL3, d)))
        table.cell(tDow, 16, row, str.tostring(array.get(dN3, d)))
