//@version=5
indicator("07 HOD LOD Timing", overlay=true)

h = hour(time, "America/New_York")
m = minute(time, "America/New_York")

inRTH = (h == 9 and m >= 30) or (h >= 10 and h < 16)
isOpen = h == 9 and m == 30
isLastRthBar = h == 15 and m == 45

var float dayHigh = na
var float dayLow = na
var int hodHour = na
var int lodHour = na

bucket() =>
    if h == 9
        0
    else if h == 10
        1
    else if h == 11
        2
    else if h == 12
        3
    else if h == 13
        4
    else if h == 14
        5
    else if h == 15
        6
    else
        -1

if isOpen
    dayHigh := high
    dayLow := low
    hodHour := 0
    lodHour := 0
else if inRTH and not na(dayHigh)
    if high > dayHigh
        dayHigh := high
        hodHour := bucket()
    if low < dayLow
        dayLow := low
        lodHour := bucket()

var int totalDays = 0
var int[] hodCount = array.new_int(7, 0)
var int[] lodCount = array.new_int(7, 0)

if isLastRthBar and not na(dayHigh)
    totalDays += 1
    if not na(hodHour) and hodHour >= 0 and hodHour <= 6
        array.set(hodCount, hodHour, array.get(hodCount, hodHour) + 1)
    if not na(lodHour) and lodHour >= 0 and lodHour <= 6
        array.set(lodCount, lodHour, array.get(lodCount, lodHour) + 1)
