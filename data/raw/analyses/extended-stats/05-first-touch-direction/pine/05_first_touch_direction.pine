//@version=5
indicator("05 First Touch Direction", overlay=true)

h = hour(time, "America/New_York")
m = minute(time, "America/New_York")

isOpenBar = h == 9 and m == 30
isAfter = (h == 9 and m == 45) or (h == 10) or (h == 11) or (h == 12) or (h == 13) or (h == 14) or (h == 15)

var float oh = na
var float ol = na
var bool first_done = false
var int first_dir = 0  // 1=high first, -1=low first, 2=both same bar

if isOpenBar
    oh := high
    ol := low
    first_done := false
    first_dir := 0

postRTH = isAfter and not na(oh) and not isOpenBar

if postRTH and not first_done
    hh = high >= oh
    ll = low <= ol
    if hh and ll
        first_done := true
        first_dir := 2
    else if hh
        first_done := true
        first_dir := 1
    else if ll
        first_done := true
        first_dir := -1

var int totalDays = 0
var int firstHigh = 0
var int firstLow = 0
var int firstAmbig = 0
var int neverHit = 0

isLastRthBar = h == 15 and m == 45
if isLastRthBar and not na(oh)
    totalDays += 1
    if first_dir == 1
        firstHigh += 1
    else if first_dir == -1
        firstLow += 1
    else if first_dir == 2
        firstAmbig += 1
    else
        neverHit += 1
