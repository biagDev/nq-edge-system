//@version=5
indicator("08 Range Stats", overlay=true)

h = hour(time, "America/New_York")
m = minute(time, "America/New_York")

inRTH = (h == 9 and m >= 30) or (h >= 10 and h < 16)
isOpen = h == 9 and m == 30
isLastRthBar = h == 15 and m == 45

var float openRange = na
var float dayHigh = na
var float dayLow = na

if isOpen
    openRange := high - low
    dayHigh := high
    dayLow := low
else if inRTH and not na(dayHigh)
    dayHigh := math.max(dayHigh, high)
    dayLow := math.min(dayLow, low)

var int totalDays = 0
var float sumOpenRange = 0.0
var float sumDayRange = 0.0
var float sumOpenPctOfDay = 0.0
var int days_or_lt_25 = 0
var int days_or_25_50 = 0
var int days_or_50_75 = 0
var int days_or_75_100 = 0

if isLastRthBar and not na(openRange)
    totalDays += 1
    sumOpenRange += openRange
    dayRange = dayHigh - dayLow
    sumDayRange += dayRange
    pct = dayRange > 0 ? (openRange / dayRange) * 100.0 : 0.0
    sumOpenPctOfDay += pct
    if pct < 25
        days_or_lt_25 += 1
    else if pct < 50
        days_or_25_50 += 1
    else if pct < 75
        days_or_50_75 += 1
    else
        days_or_75_100 += 1
