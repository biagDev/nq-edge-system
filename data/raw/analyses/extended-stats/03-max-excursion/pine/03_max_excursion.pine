//@version=5
// v2 — fixed denominator inconsistency from v1.
// All counters now commit at isLastRthBar via per-day variables.

indicator("03 Max Excursion FIXED", overlay=true)

h = hour(time, "America/New_York")
m = minute(time, "America/New_York")

isOpenBar = h == 9 and m == 30
isAfter = (h == 9 and m == 45) or (h == 10) or (h == 11) or (h == 12) or (h == 13) or (h == 14) or (h == 15)
isLastRthBar = h == 15 and m == 45

var float oh = na
var float ol = na
var float orange = na
var bool hitEither = false
var float maxExcUp = 0.0
var float maxExcDown = 0.0
var float excPctOfRange = na  // per-day result; committed at EOD

if isOpenBar
    oh := high
    ol := low
    orange := high - low
    hitEither := false
    maxExcUp := 0.0
    maxExcDown := 0.0
    excPctOfRange := na

postRTH = isAfter and not na(oh) and not isOpenBar

if postRTH and not hitEither
    if high > oh
        maxExcUp := math.max(maxExcUp, high - oh)
    if low < ol
        maxExcDown := math.max(maxExcDown, ol - low)
    if high >= oh or low <= ol
        hitEither := true
        excPre = math.max(maxExcUp, maxExcDown)
        if orange > 0
            excPctOfRange := (excPre / orange) * 100.0

// All counters gate on isLastRthBar — denominator is consistent
var int totalDays = 0
var int days_no_exc = 0
var int days_le_25 = 0
var int days_25_50 = 0
var int days_50_100 = 0
var int days_100_200 = 0
var int days_200plus = 0
var int days_never = 0
var float sumExcPct = 0.0
var int hitDaysCounter = 0

if isLastRthBar and not na(oh)
    totalDays += 1
    if not hitEither
        days_never += 1
    else if not na(excPctOfRange)
        if excPctOfRange == 0
            days_no_exc += 1
        else
            sumExcPct += excPctOfRange
            hitDaysCounter += 1
            if excPctOfRange <= 25
                days_le_25 += 1
            else if excPctOfRange <= 50
                days_25_50 += 1
            else if excPctOfRange <= 100
                days_50_100 += 1
            else if excPctOfRange <= 200
                days_100_200 += 1
            else
                days_200plus += 1
