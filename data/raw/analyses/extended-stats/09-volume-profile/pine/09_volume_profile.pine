//@version=5
indicator("09 Volume Profile", overlay=false)

h = hour(time, "America/New_York")
m = minute(time, "America/New_York")

inRTH = (h == 9 and m >= 30) or (h >= 10 and h < 16)

bucketIdx() =>
    if h == 9 and m == 30
        0
    else if h == 9 and m == 45
        1
    else if h == 10 and m == 0
        2
    else if h == 10 and m == 15
        3
    else if h == 10 and m == 30
        4
    else if h == 10 and m == 45
        5
    else if h == 11 and m == 0
        6
    else if h == 11 and m == 30
        7
    else if h == 12 and m == 0
        8
    else if h == 13 and m == 0
        9
    else if h == 14 and m == 0
        10
    else if h == 15 and m == 0
        11
    else if h == 15 and m == 30
        12
    else if h == 15 and m == 45
        13
    else
        -1

var float[] sumVol = array.new_float(14, 0.0)
var int[] cnt = array.new_int(14, 0)

if inRTH
    bi = bucketIdx()
    if bi >= 0
        array.set(sumVol, bi, array.get(sumVol, bi) + volume)
        array.set(cnt, bi, array.get(cnt, bi) + 1)
