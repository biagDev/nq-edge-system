//@version=5
// v2 — fixed denominator inconsistency from v1.
// All counters now commit at isLastRthBar via per-day flag.

indicator("02 Time To Retest FIXED", overlay=true)

h = hour(time, "America/New_York")
m = minute(time, "America/New_York")

isOpenBar = h == 9 and m == 30
isAfter = (h == 9 and m == 45) or (h == 10) or (h == 11) or (h == 12) or (h == 13) or (h == 14) or (h == 15)
isLastRthBar = h == 15 and m == 45

var float oh = na
var float ol = na
var int barsAfter = 0
var bool hitEither = false
var int barsToHit = na  // per-day; captured at first hit, committed at EOD

if isOpenBar
    oh := high
    ol := low
    barsAfter := 0
    hitEither := false
    barsToHit := na

postRTH = isAfter and not na(oh) and not isOpenBar

if postRTH
    barsAfter += 1
    if not hitEither
        if high >= oh or low <= ol
            hitEither := true
            barsToHit := barsAfter

// All counters gate on isLastRthBar — denominator is consistent
var int totalDays = 0
var int b1 = 0
var int b2 = 0
var int b3 = 0
var int b4 = 0
var int b5to8 = 0
var int b9to16 = 0
var int b17plus = 0
var int never = 0
var int sumBarsHit = 0
var int hitDays = 0

if isLastRthBar and not na(oh)
    totalDays += 1
    if hitEither and not na(barsToHit)
        hitDays += 1
        sumBarsHit += barsToHit
        if barsToHit == 1
            b1 += 1
        else if barsToHit == 2
            b2 += 1
        else if barsToHit == 3
            b3 += 1
        else if barsToHit == 4
            b4 += 1
        else if barsToHit <= 8
            b5to8 += 1
        else if barsToHit <= 16
            b9to16 += 1
        else
            b17plus += 1
    else
        never += 1
