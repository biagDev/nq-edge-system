//@version=5
indicator("930 Hit Stats", overlay=true, max_labels_count=500)

h = hour(time, "America/New_York")
m = minute(time, "America/New_York")
dow = dayofweek(time, "America/New_York")
isOpenBar = h == 9  and m == 30
isBar945  = h == 9  and m == 45
isBar1000 = h == 10 and m == 0

var float openHigh = na
var float openLow  = na
var int   openDow  = na

var bool hiHit1000 = false
var bool loHit1000 = false
var bool hiHit1015 = false
var bool loHit1015 = false

var int totalDays   = 0
var int either1000  = 0
var int both1000    = 0
var int hiOnly1000  = 0
var int loOnly1000  = 0
var int neither1000 = 0
var int hiAny1000   = 0
var int loAny1000   = 0
var int either1015  = 0
var int both1015    = 0
var int hiOnly1015  = 0
var int loOnly1015  = 0
var int neither1015 = 0
var int hiAny1015   = 0
var int loAny1015   = 0

var int[] dowDays      = array.new_int(8, 0)
var int[] dowEither10  = array.new_int(8, 0)
var int[] dowBoth10    = array.new_int(8, 0)
var int[] dowHiOnly10  = array.new_int(8, 0)
var int[] dowLoOnly10  = array.new_int(8, 0)
var int[] dowNeither10 = array.new_int(8, 0)
var int[] dowEither15  = array.new_int(8, 0)
var int[] dowBoth15    = array.new_int(8, 0)
var int[] dowHiOnly15  = array.new_int(8, 0)
var int[] dowLoOnly15  = array.new_int(8, 0)
var int[] dowNeither15 = array.new_int(8, 0)

if isOpenBar
    openHigh := high
    openLow  := low
    openDow  := dow
    hiHit1000 := false
    loHit1000 := false
    hiHit1015 := false
    loHit1015 := false

if isBar945 and not na(openHigh)
    if high >= openHigh
        hiHit1000 := true
        hiHit1015 := true
    if low <= openLow
        loHit1000 := true
        loHit1015 := true

if isBar1000 and not na(openHigh)
    if high >= openHigh
        hiHit1015 := true
    if low <= openLow
        loHit1015 := true

    totalDays += 1
    if hiHit1000
        hiAny1000 += 1
    if loHit1000
        loAny1000 += 1
    if hiHit1000 and loHit1000
        both1000 += 1
        either1000 += 1
    else if hiHit1000
        hiOnly1000 += 1
        either1000 += 1
    else if loHit1000
        loOnly1000 += 1
        either1000 += 1
    else
        neither1000 += 1

    if hiHit1015
        hiAny1015 += 1
    if loHit1015
        loAny1015 += 1
    if hiHit1015 and loHit1015
        both1015 += 1
        either1015 += 1
    else if hiHit1015
        hiOnly1015 += 1
        either1015 += 1
    else if loHit1015
        loOnly1015 += 1
        either1015 += 1
    else
        neither1015 += 1

    d = openDow
    if d >= 2 and d <= 6
        array.set(dowDays, d, array.get(dowDays, d) + 1)
        if hiHit1000 and loHit1000
            array.set(dowBoth10,   d, array.get(dowBoth10,   d) + 1)
            array.set(dowEither10, d, array.get(dowEither10, d) + 1)
        else if hiHit1000
            array.set(dowHiOnly10, d, array.get(dowHiOnly10, d) + 1)
            array.set(dowEither10, d, array.get(dowEither10, d) + 1)
        else if loHit1000
            array.set(dowLoOnly10, d, array.get(dowLoOnly10, d) + 1)
            array.set(dowEither10, d, array.get(dowEither10, d) + 1)
        else
            array.set(dowNeither10, d, array.get(dowNeither10, d) + 1)
        if hiHit1015 and loHit1015
            array.set(dowBoth15,   d, array.get(dowBoth15,   d) + 1)
            array.set(dowEither15, d, array.get(dowEither15, d) + 1)
        else if hiHit1015
            array.set(dowHiOnly15, d, array.get(dowHiOnly15, d) + 1)
            array.set(dowEither15, d, array.get(dowEither15, d) + 1)
        else if loHit1015
            array.set(dowLoOnly15, d, array.get(dowLoOnly15, d) + 1)
            array.set(dowEither15, d, array.get(dowEither15, d) + 1)
        else
            array.set(dowNeither15, d, array.get(dowNeither15, d) + 1)

f_pct(num, den) =>
    den > 0 ? num * 100.0 / den : 0.0

var table tAgg = table.new(position.top_right, 5, 10, border_width=1)
var table tDow = table.new(position.middle_right, 12, 7, border_width=1)

if barstate.islast
    table.cell(tAgg, 0, 0, "Aggregate",      bgcolor=color.navy, text_color=color.white)
    table.cell(tAgg, 1, 0, "10:00 #",        bgcolor=color.navy, text_color=color.white)
    table.cell(tAgg, 2, 0, "10:00 %",        bgcolor=color.navy, text_color=color.white)
    table.cell(tAgg, 3, 0, "10:15 #",        bgcolor=color.navy, text_color=color.white)
    table.cell(tAgg, 4, 0, "10:15 %",        bgcolor=color.navy, text_color=color.white)

    table.cell(tAgg, 0, 1, "Total days")
    table.cell(tAgg, 1, 1, str.tostring(totalDays))
    table.cell(tAgg, 2, 1, "100")
    table.cell(tAgg, 3, 1, str.tostring(totalDays))
    table.cell(tAgg, 4, 1, "100")

    table.cell(tAgg, 0, 2, "Either side")
    table.cell(tAgg, 1, 2, str.tostring(either1000))
    table.cell(tAgg, 2, 2, str.tostring(f_pct(either1000, totalDays), "#.##"))
    table.cell(tAgg, 3, 2, str.tostring(either1015))
    table.cell(tAgg, 4, 2, str.tostring(f_pct(either1015, totalDays), "#.##"))

    table.cell(tAgg, 0, 3, "Both sides")
    table.cell(tAgg, 1, 3, str.tostring(both1000))
    table.cell(tAgg, 2, 3, str.tostring(f_pct(both1000, totalDays), "#.##"))
    table.cell(tAgg, 3, 3, str.tostring(both1015))
    table.cell(tAgg, 4, 3, str.tostring(f_pct(both1015, totalDays), "#.##"))

    table.cell(tAgg, 0, 4, "High only")
    table.cell(tAgg, 1, 4, str.tostring(hiOnly1000))
    table.cell(tAgg, 2, 4, str.tostring(f_pct(hiOnly1000, totalDays), "#.##"))
    table.cell(tAgg, 3, 4, str.tostring(hiOnly1015))
    table.cell(tAgg, 4, 4, str.tostring(f_pct(hiOnly1015, totalDays), "#.##"))

    table.cell(tAgg, 0, 5, "Low only")
    table.cell(tAgg, 1, 5, str.tostring(loOnly1000))
    table.cell(tAgg, 2, 5, str.tostring(f_pct(loOnly1000, totalDays), "#.##"))
    table.cell(tAgg, 3, 5, str.tostring(loOnly1015))
    table.cell(tAgg, 4, 5, str.tostring(f_pct(loOnly1015, totalDays), "#.##"))

    table.cell(tAgg, 0, 6, "Neither")
    table.cell(tAgg, 1, 6, str.tostring(neither1000))
    table.cell(tAgg, 2, 6, str.tostring(f_pct(neither1000, totalDays), "#.##"))
    table.cell(tAgg, 3, 6, str.tostring(neither1015))
    table.cell(tAgg, 4, 6, str.tostring(f_pct(neither1015, totalDays), "#.##"))

    table.cell(tAgg, 0, 7, "High touched (any)")
    table.cell(tAgg, 1, 7, str.tostring(hiAny1000))
    table.cell(tAgg, 2, 7, str.tostring(f_pct(hiAny1000, totalDays), "#.##"))
    table.cell(tAgg, 3, 7, str.tostring(hiAny1015))
    table.cell(tAgg, 4, 7, str.tostring(f_pct(hiAny1015, totalDays), "#.##"))

    table.cell(tAgg, 0, 8, "Low touched (any)")
    table.cell(tAgg, 1, 8, str.tostring(loAny1000))
    table.cell(tAgg, 2, 8, str.tostring(f_pct(loAny1000, totalDays), "#.##"))
    table.cell(tAgg, 3, 8, str.tostring(loAny1015))
    table.cell(tAgg, 4, 8, str.tostring(f_pct(loAny1015, totalDays), "#.##"))

    headers = array.from("DOW", "N", "Either10%", "Both10%", "HiOnly10", "LoOnly10", "Neither10", "Either15%", "Both15%", "HiOnly15", "LoOnly15", "Neither15")
    for i = 0 to 11
        table.cell(tDow, i, 0, array.get(headers, i), bgcolor=color.navy, text_color=color.white)
    dowNames = array.from("", "", "Mon", "Tue", "Wed", "Thu", "Fri")
    for d = 2 to 6
        n = array.get(dowDays, d)
        row = d - 1
        table.cell(tDow, 0, row, array.get(dowNames, d))
        table.cell(tDow, 1, row, str.tostring(n))
        table.cell(tDow, 2, row, str.tostring(f_pct(array.get(dowEither10, d), n), "#.##"))
        table.cell(tDow, 3, row, str.tostring(f_pct(array.get(dowBoth10,   d), n), "#.##"))
        table.cell(tDow, 4, row, str.tostring(array.get(dowHiOnly10, d)))
        table.cell(tDow, 5, row, str.tostring(array.get(dowLoOnly10, d)))
        table.cell(tDow, 6, row, str.tostring(array.get(dowNeither10, d)))
        table.cell(tDow, 7, row, str.tostring(f_pct(array.get(dowEither15, d), n), "#.##"))
        table.cell(tDow, 8, row, str.tostring(f_pct(array.get(dowBoth15,   d), n), "#.##"))
        table.cell(tDow, 9, row, str.tostring(array.get(dowHiOnly15, d)))
        table.cell(tDow, 10, row, str.tostring(array.get(dowLoOnly15, d)))
        table.cell(tDow, 11, row, str.tostring(array.get(dowNeither15, d)))
