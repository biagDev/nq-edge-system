//@version=5
indicator("6AM 4h Hit Stats", overlay=true, max_labels_count=500)

// Computes hit stats for the 4-hour candle from 6:00-10:00 ET.
// Runs on a 15m chart: H/L of the 4h candle = max/min over the
// sixteen 15m bars in 6:00-9:45.

h = hour(time, "America/New_York")
m = minute(time, "America/New_York")
dow = dayofweek(time, "America/New_York")

isInsideRange = h >= 6 and h < 10
isFirstBar    = h == 6  and m == 0
isLastInside  = h == 9  and m == 45

isPost1 = h == 10 and m == 0   // 10:00-10:15
isPost2 = h == 10 and m == 15  // 10:15-10:30 -> end "by 10:30"
isPost3 = h == 10 and m == 30  // 10:30-10:45
isPost4 = h == 10 and m == 45  // 10:45-11:00 -> end "by 11:00" (final tally)

var float candleH = na
var float candleL = na
var int   candleDow = na

if isFirstBar
    candleH := high
    candleL := low
    candleDow := dow
else if isInsideRange and not na(candleH)
    candleH := math.max(candleH, high)
    candleL := math.min(candleL, low)

var bool hi30 = false
var bool lo30 = false
var bool hi60 = false
var bool lo60 = false

if isPost1
    hi30 := false
    lo30 := false
    hi60 := false
    lo60 := false

var int totalDays = 0

var int e30 = 0
var int b30 = 0
var int ho30 = 0
var int lo30c = 0
var int n30 = 0
var int ha30 = 0
var int la30 = 0

var int e60 = 0
var int b60 = 0
var int ho60 = 0
var int lo60c = 0
var int n60 = 0
var int ha60 = 0
var int la60 = 0

var int[] dD = array.new_int(8, 0)
var int[] dE30 = array.new_int(8, 0)
var int[] dB30 = array.new_int(8, 0)
var int[] dH30 = array.new_int(8, 0)
var int[] dL30 = array.new_int(8, 0)
var int[] dN30 = array.new_int(8, 0)
var int[] dE60 = array.new_int(8, 0)
var int[] dB60 = array.new_int(8, 0)
var int[] dH60 = array.new_int(8, 0)
var int[] dL60 = array.new_int(8, 0)
var int[] dN60 = array.new_int(8, 0)

if isPost1 and not na(candleH)
    if high >= candleH
        hi30 := true
        hi60 := true
    if low <= candleL
        lo30 := true
        lo60 := true

if isPost2 and not na(candleH)
    if high >= candleH
        hi30 := true
        hi60 := true
    if low <= candleL
        lo30 := true
        lo60 := true

if isPost3 and not na(candleH)
    if high >= candleH
        hi60 := true
    if low <= candleL
        lo60 := true

if isPost4 and not na(candleH)
    if high >= candleH
        hi60 := true
    if low <= candleL
        lo60 := true

    totalDays += 1

    if hi30
        ha30 += 1
    if lo30
        la30 += 1
    if hi30 and lo30
        b30 += 1
        e30 += 1
    else if hi30
        ho30 += 1
        e30 += 1
    else if lo30
        lo30c += 1
        e30 += 1
    else
        n30 += 1

    if hi60
        ha60 += 1
    if lo60
        la60 += 1
    if hi60 and lo60
        b60 += 1
        e60 += 1
    else if hi60
        ho60 += 1
        e60 += 1
    else if lo60
        lo60c += 1
        e60 += 1
    else
        n60 += 1

    d = candleDow
    if d >= 2 and d <= 6
        array.set(dD, d, array.get(dD, d) + 1)
        if hi30 and lo30
            array.set(dB30, d, array.get(dB30, d) + 1)
            array.set(dE30, d, array.get(dE30, d) + 1)
        else if hi30
            array.set(dH30, d, array.get(dH30, d) + 1)
            array.set(dE30, d, array.get(dE30, d) + 1)
        else if lo30
            array.set(dL30, d, array.get(dL30, d) + 1)
            array.set(dE30, d, array.get(dE30, d) + 1)
        else
            array.set(dN30, d, array.get(dN30, d) + 1)

        if hi60 and lo60
            array.set(dB60, d, array.get(dB60, d) + 1)
            array.set(dE60, d, array.get(dE60, d) + 1)
        else if hi60
            array.set(dH60, d, array.get(dH60, d) + 1)
            array.set(dE60, d, array.get(dE60, d) + 1)
        else if lo60
            array.set(dL60, d, array.get(dL60, d) + 1)
            array.set(dE60, d, array.get(dE60, d) + 1)
        else
            array.set(dN60, d, array.get(dN60, d) + 1)

f_pct(num, den) =>
    den > 0 ? num * 100.0 / den : 0.0

var table tAgg = table.new(position.top_right, 5, 10, border_width=1)
var table tDow = table.new(position.middle_right, 12, 7, border_width=1)

if barstate.islast
    table.cell(tAgg, 0, 0, "Aggregate", bgcolor=color.navy, text_color=color.white)
    table.cell(tAgg, 1, 0, "By 10:30 #",  bgcolor=color.navy, text_color=color.white)
    table.cell(tAgg, 2, 0, "By 10:30 %",  bgcolor=color.navy, text_color=color.white)
    table.cell(tAgg, 3, 0, "By 11:00 #",  bgcolor=color.navy, text_color=color.white)
    table.cell(tAgg, 4, 0, "By 11:00 %",  bgcolor=color.navy, text_color=color.white)

    table.cell(tAgg, 0, 1, "Total days")
    table.cell(tAgg, 1, 1, str.tostring(totalDays))
    table.cell(tAgg, 2, 1, "100")
    table.cell(tAgg, 3, 1, str.tostring(totalDays))
    table.cell(tAgg, 4, 1, "100")

    table.cell(tAgg, 0, 2, "Either side")
    table.cell(tAgg, 1, 2, str.tostring(e30))
    table.cell(tAgg, 2, 2, str.tostring(f_pct(e30, totalDays), "#.##"))
    table.cell(tAgg, 3, 2, str.tostring(e60))
    table.cell(tAgg, 4, 2, str.tostring(f_pct(e60, totalDays), "#.##"))

    table.cell(tAgg, 0, 3, "Both sides")
    table.cell(tAgg, 1, 3, str.tostring(b30))
    table.cell(tAgg, 2, 3, str.tostring(f_pct(b30, totalDays), "#.##"))
    table.cell(tAgg, 3, 3, str.tostring(b60))
    table.cell(tAgg, 4, 3, str.tostring(f_pct(b60, totalDays), "#.##"))

    table.cell(tAgg, 0, 4, "High only")
    table.cell(tAgg, 1, 4, str.tostring(ho30))
    table.cell(tAgg, 2, 4, str.tostring(f_pct(ho30, totalDays), "#.##"))
    table.cell(tAgg, 3, 4, str.tostring(ho60))
    table.cell(tAgg, 4, 4, str.tostring(f_pct(ho60, totalDays), "#.##"))

    table.cell(tAgg, 0, 5, "Low only")
    table.cell(tAgg, 1, 5, str.tostring(lo30c))
    table.cell(tAgg, 2, 5, str.tostring(f_pct(lo30c, totalDays), "#.##"))
    table.cell(tAgg, 3, 5, str.tostring(lo60c))
    table.cell(tAgg, 4, 5, str.tostring(f_pct(lo60c, totalDays), "#.##"))

    table.cell(tAgg, 0, 6, "Neither")
    table.cell(tAgg, 1, 6, str.tostring(n30))
    table.cell(tAgg, 2, 6, str.tostring(f_pct(n30, totalDays), "#.##"))
    table.cell(tAgg, 3, 6, str.tostring(n60))
    table.cell(tAgg, 4, 6, str.tostring(f_pct(n60, totalDays), "#.##"))

    table.cell(tAgg, 0, 7, "High touched (any)")
    table.cell(tAgg, 1, 7, str.tostring(ha30))
    table.cell(tAgg, 2, 7, str.tostring(f_pct(ha30, totalDays), "#.##"))
    table.cell(tAgg, 3, 7, str.tostring(ha60))
    table.cell(tAgg, 4, 7, str.tostring(f_pct(ha60, totalDays), "#.##"))

    table.cell(tAgg, 0, 8, "Low touched (any)")
    table.cell(tAgg, 1, 8, str.tostring(la30))
    table.cell(tAgg, 2, 8, str.tostring(f_pct(la30, totalDays), "#.##"))
    table.cell(tAgg, 3, 8, str.tostring(la60))
    table.cell(tAgg, 4, 8, str.tostring(f_pct(la60, totalDays), "#.##"))

    headers = array.from("DOW", "N", "Eit30%", "Bth30%", "Hi30", "Lo30", "Nei30", "Eit60%", "Bth60%", "Hi60", "Lo60", "Nei60")
    for i = 0 to 11
        table.cell(tDow, i, 0, array.get(headers, i), bgcolor=color.navy, text_color=color.white)
    dowNames = array.from("", "", "Mon", "Tue", "Wed", "Thu", "Fri")
    for d = 2 to 6
        n = array.get(dD, d)
        row = d - 1
        table.cell(tDow, 0,  row, array.get(dowNames, d))
        table.cell(tDow, 1,  row, str.tostring(n))
        table.cell(tDow, 2,  row, str.tostring(f_pct(array.get(dE30, d), n), "#.##"))
        table.cell(tDow, 3,  row, str.tostring(f_pct(array.get(dB30, d), n), "#.##"))
        table.cell(tDow, 4,  row, str.tostring(array.get(dH30, d)))
        table.cell(tDow, 5,  row, str.tostring(array.get(dL30, d)))
        table.cell(tDow, 6,  row, str.tostring(array.get(dN30, d)))
        table.cell(tDow, 7,  row, str.tostring(f_pct(array.get(dE60, d), n), "#.##"))
        table.cell(tDow, 8,  row, str.tostring(f_pct(array.get(dB60, d), n), "#.##"))
        table.cell(tDow, 9,  row, str.tostring(array.get(dH60, d)))
        table.cell(tDow, 10, row, str.tostring(array.get(dL60, d)))
        table.cell(tDow, 11, row, str.tostring(array.get(dN60, d)))
