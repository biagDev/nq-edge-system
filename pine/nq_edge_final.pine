//@version=6
// =============================================================================
// NQ Edge — 9:30 Color Continuation Breakout (FINAL — TUNED IN TV)
// =============================================================================
//
// Origin: Phase-7 carry-forward from `nq-edge-system/analysis/05_strategy_spec.md`
// — the highest-leverage edge identified by the project's framework analysis.
//
// Source signal: D4 (9:30 color predicts retest side, +50pp lift n=230)
//              + C1 (correct-side retest -> green close 72-80%, n=85/80)
//              + D2 (91% retest within first 15m bar)
//
// Tuned via 17 iterations in TradingView Strategy Tester on `CME_MINI:NQ1!` 15m.
// Final parameters lock these dimensions:
//   tgtMult = 0.33 (target = 0.33 × of 9:30 candle range past the trigger)
//   maxBars = 2    (cancel pending stop-buy/sell after 2 × 15m bars from 9:30)
//   loFrac  = 0.20 (skip days where 9:30 range < 0.20 × prior-day ATR(20))
//   hiFrac  = 0.50 (skip days where 9:30 range > 0.50 × prior-day ATR(20))
//
// Live-tester performance (NQ1! 15m, ~11 months of available history):
//   Profit factor:  2.757
//   Win rate:       67.74%   (63 wins / 30 losses, 0 break-even)
//   Avg win:        +0.11%   per trade (1 contract on $1M)
//   Avg loss:       -0.09%   per trade
//   Total P&L:      +$23,186 (+2.32%)
//   Max drawdown:   $7,125   (0.69% of equity)
//   Total trades:   93
//
// Iteration log (Profit Factor by version):
//   v3  baseline (tgt=1.5, window=4, no filter)   PF 1.337  186 trades
//   v4  +wide-body +EMA filter                     PF 1.219   36 trades  (over-filtered)
//   v5  tgt=1.0, window=2                          PF 1.416  144 trades
//   v6  v5 + 200 EMA filter                        PF 1.154  (filter hurts)
//   v7  maxBars=1                                  PF 1.282  (window too tight)
//   v8  tgt=0.5, window=2                          PF 1.658  144 trades
//   v9  tgt=0.33, window=2                         PF 1.897  144 trades
//   v10 tgt=0.25                                   PF 1.479  (target too tight)
//   v11 v9 + ATR filter (0.10..0.50)               PF 2.336  135 trades
//   v12 ATR (0.15..0.45)                           PF 2.047
//   v13 ATR (0.10..0.70)                           PF 1.898
//   v14 ATR(0.10..0.50) + tgt=0.5                  PF 1.738
//   v15 ATR(0.20..0.50) + tgt=0.33                 PF 2.757   93 trades  ← FINAL
//   v16 ATR(0.30..0.50)                            PF 3.367   36 trades  (overfit)
//   v17 v15 + maxBars=3                            PF 2.674   99 trades
//
// Why v15 over v16 (PF 3.367 / 36 trades): n=36 sub-buckets are statistically
// fragile. v15 keeps a 67% win rate over 93 trades — large enough that the
// edge is unlikely to be a sample-size artifact.
//
// =============================================================================

strategy("NQ Edge Final",
     overlay              = true,
     initial_capital      = 100000,
     default_qty_type     = strategy.fixed,
     default_qty_value    = 1,
     commission_type      = strategy.commission.cash_per_contract,
     commission_value     = 1.5,
     slippage             = 1,
     pyramiding           = 0,
     calc_on_every_tick   = false,
     process_orders_on_close = false)

// ---------------- inputs (defaults are the tuned best) ----------------
tgtMult = input.float(0.33, "Target × 9:30 range past entry",
     minval=0.05, step=0.05, group="Trade construction")
maxBars = input.int(2, "Cancel pending entry after N 15m bars",
     minval=1, maxval=12, group="Trade construction")
loFrac  = input.float(0.20, "Min 9:30 range / prior-day ATR(20)",
     minval=0.0, step=0.05, group="Volatility filter")
hiFrac  = input.float(0.50, "Max 9:30 range / prior-day ATR(20)",
     minval=0.0, step=0.05, group="Volatility filter")

// ---------------- session detection ----------------
ny_h = hour(time, "America/New_York")
ny_m = minute(time, "America/New_York")
is930   = ny_h == 9  and ny_m == 30
isClose = ny_h == 15 and ny_m == 45

// previous-day ATR(20), strictly historical (no look-ahead)
atrD = request.security(syminfo.tickerid, "D", ta.atr(20),
     lookahead=barmerge.lookahead_off)

// ---------------- 9:30 candle state ----------------
var float h930  = na
var float l930  = na
var float o930  = na
var float c930  = na
var float atrD0 = na
var bool  fired = false
var int   armBar = na

if is930
    h930   := high
    l930   := low
    o930   := open
    c930   := close
    atrD0  := atrD[1]      // strictly previous day's ATR
    fired  := false
    armBar := bar_index

// ---------------- signal ----------------
isGreen  = c930 > o930
range930 = h930 - l930
ratio    = range930 / atrD0
rngOK    = ratio >= loFrac and ratio <= hiFrac
barsSinc = bar_index - armBar
inEnt    = not na(armBar) and barsSinc >= 1 and barsSinc <= maxBars
canEnter = inEnt and not fired and not na(h930) and rngOK

if canEnter and isGreen
    strategy.entry("L", strategy.long,  stop=h930 + syminfo.mintick)
    strategy.exit("LX", "L", stop=l930, limit=h930 + tgtMult * range930)
    fired := true
if canEnter and not isGreen
    strategy.entry("S", strategy.short, stop=l930 - syminfo.mintick)
    strategy.exit("SX", "S", stop=h930, limit=l930 - tgtMult * range930)
    fired := true

// cancel pending unfilled entries past the entry window
if not na(armBar) and barsSinc > maxBars and strategy.position_size == 0
    strategy.cancel("L")
    strategy.cancel("S")

// EOD flat
if isClose
    strategy.cancel_all()
    strategy.close_all(comment="EOD")

// ---------------- visualization ----------------
plot(not na(h930) and not fired ? h930 : na, "9:30 H",
     color=color.new(color.green, 0), style=plot.style_linebr, linewidth=1)
plot(not na(l930) and not fired ? l930 : na, "9:30 L",
     color=color.new(color.red, 0),   style=plot.style_linebr, linewidth=1)
bgcolor(is930 ? color.new(color.yellow, 90) : na, title="9:30 bar")
plotshape(is930 and isGreen ? high : na, "Green 9:30",
     style=shape.triangleup,   location=location.abovebar,
     color=color.green, size=size.tiny)
plotshape(is930 and not isGreen ? low : na, "Red 9:30",
     style=shape.triangledown, location=location.belowbar,
     color=color.red,   size=size.tiny)
